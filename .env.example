# NavPMS environment configuration (copy to .env and fill in)
# ---------------------------------------------------------------------------
SECRET_KEY=change-me-generate-with-get_random_secret_key
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# --- MySQL (XAMPP) ----------------------------------------------------------
# Use a DEDICATED empty database for NavPMS. Do not reuse a name already taken by
# another app in your MySQL/MariaDB instance.
DB_ENGINE=django.db.backends.mysql
DB_NAME=nav_pms
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# --- Email (dev: print to console) -----------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=NavPMS <no-reply@navpms.local>
EMAIL_HOST=localhost
EMAIL_PORT=25
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False

# --- App --------------------------------------------------------------------
SITE_NAME=NavPMS
SITE_URL=http://127.0.0.1:8000
